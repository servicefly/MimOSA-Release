# ---------------------------------------------------------------------------
# MimOSA environment template
#
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
#
# The ".env" file is git-ignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# --- LLM: Abacus.AI RouteLLM (default cloud provider) ---
# Your Abacus.AI API key. Required when USE_LOCAL_LLM=false.
ABACUS_API_KEY=your_key_here

# Optional: override the RouteLLM endpoint (leave as-is for the default).
# ABACUS_BASE_URL=https://routellm.abacus.ai/v1

# --- LLM: local-first / privacy mode ---
# When "true", MimOSA routes all LLM calls to a local, on-device model
# (Ollama / llama.cpp) and never contacts the cloud. The Privacy Guard can
# also force this per-conversation for sensitive topics.
USE_LOCAL_LLM=false

# Optional: Ollama daemon URL used by the (future) local provider.
# OLLAMA_BASE_URL=http://localhost:11434

# --- Voice: wake word ---
# Picovoice Porcupine access key for wake-word detection.
# Get a free key at https://console.picovoice.ai/
# If unset/invalid, MimOSA falls back to a dependency-free energy detector.
PORCUPINE_ACCESS_KEY=your_porcupine_key_here

# The phrase that activates MimOSA. Note: Porcupine has no built-in model for
# "hey mimosa", so without a custom .ppn it maps to a built-in keyword
# ("jarvis") or the energy fallback. Provide a custom keyword file for the
# exact phrase.
WAKE_WORD=hey mimosa

# --- Voice: speech-to-text (Whisper, local) ---
# Whisper model size: tiny, base, small, medium, large (and .en variants).
# Smaller = faster + lighter; larger = more accurate. "base" is a good start.
WHISPER_MODEL=base

# --- Voice: text-to-speech (Piper, local) ---
# Piper voice name or path to a .onnx voice model.
PIPER_VOICE=en_US-lessac-medium

# --- Audio devices ---
# Input (microphone) and output (speaker) device selection. Use "default" to
# let the OS pick, or set a specific device index (see scripts/test_voice_loop.py
# which can list available devices).
AUDIO_INPUT_DEVICE=default
AUDIO_OUTPUT_DEVICE=default

# --- Intent router & skills (M1.3) ---
# Minimum classification confidence to accept an intent. Below this, the router
# falls back to treating the utterance as a general question.
INTENT_CONFIDENCE_THRESHOLD=0.7

# Number of conversation turns (user+assistant pairs) kept for context.
MAX_CONVERSATION_HISTORY=10

# Weather skill: wttr.in is used by default and needs NO key. These are
# optional. DEFAULT_LOCATION is used when the user doesn't name a place
# ("what's the weather?"); leave blank to let wttr.in auto-detect by IP.
# WEATHER_API_KEY is reserved for a future OpenWeatherMap backend.
WEATHER_API_KEY=
DEFAULT_LOCATION=

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
